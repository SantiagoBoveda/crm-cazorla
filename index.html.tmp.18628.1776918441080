/* ── Dashboard ── */
function DashboardScreen({theme, data}) {
  const bg=theme==='dark'?'#191b0d':'#fff';
  const border=theme==='dark'?'#2e3018':'#dad0be';
  const textMuted=theme==='dark'?'#707558':'#6e5f4e';
  const surface2=theme==='dark'?'#212410':'#f0ebe0';

  const ventas = data.ventas;
  const clientes = data.clientes;
  const facturas = data.facturas;

  const clientesActivos = clientes.filter(c=>(c.Estado||'').toLowerCase()==='activo').length;
  const paises = [...new Set(clientes.map(c=>c.Pais).filter(Boolean))].length;
  const facturasVencidas = facturas.filter(f=>(f.Estado||f.EstadoFactura||'').toLowerCase()==='vencida');
  const montoVencido = facturasVencidas.reduce((s,f)=>s+(parseFloat(f.Monto)||0),0);

  const ventasRecientes = ventas.slice(-5).reverse().map(v=>({
    cliente: v.Cliente||'',
    producto: v.Producto||v.Categoria||'',
    pais: v.Pais||'',
    monto: v.ValorUSD ? `$${Number(v.ValorUSD).toLocaleString('es-AR')}` : '—',
    estado: (v.Etapa||v.Estado||'').toLowerCase(),
  }));

  const inventario = data.inventario;
  const aceitunas = inventario.filter(i=>(i.Categoria||i.Producto||'').toLowerCase().includes('aceituna'));
  const maxStock = Math.max(...aceitunas.map(i=>parseFloat(i.StockActual)||0), 1);

  return (
    <div>
      <PageHeader title="📊 Dashboard" subtitle="Grupo Cazorla · Resumen ejecutivo"/>
      <div style={{display:'grid',gridTemplateColumns:'repeat(4,1fr)',gap:'14px',marginBottom:'24px'}}>
        <StatCard label="Ventas registradas" value={ventas.length} sub="total en Sheets" barColor="#a7001d"/>
        <StatCard label="Clientes activos" value={clientesActivos} sub={`${paises} países`} barColor="#722F37" subColor="#9e8e78"/>
        <StatCard label="Facturas vencidas" value={facturasVencidas.length} sub={montoVencido?`$${montoVencido.toLocaleString('es-AR')} pendiente`:''} barColor="#b45309" subColor="#db473c"/>
        <StatCard label="Total clientes" value={clientes.length} sub="en directorio" barColor="#6b7215"/>
      </div>
      {aceitunas.length > 0 && (
        <div style={{background:bg,border:`1px solid ${border}`,borderRadius:'12px',padding:'18px 20px',marginBottom:'24px',boxShadow:'0 1px 4px rgba(167,0,29,.06)'}}>
          <h3 style={{fontSize:'13px',fontWeight:600,color:textMuted,marginBottom:'14px'}}>Stock inventario (aceitunas)</h3>
          {aceitunas.slice(0,5).map((item,i)=>{
            const stock = parseFloat(item.StockActual)||0;
            const pct = Math.round((stock/maxStock)*100);
            return (
              <div key={i} style={{display:'flex',alignItems:'center',gap:'10px',marginBottom:'8px'}}>
                <div style={{fontSize:'12px',color:theme==='dark'?'#8a9060':'#5c4e3a',width:'190px',flexShrink:0,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{item.Producto}</div>
                <div style={{flex:1,height:'8px',background:surface2,borderRadius:'4px',overflow:'hidden'}}>
                  <div style={{width:`${pct}%`,height:'100%',background:'#a7001d',borderRadius:'4px'}}></div>
                </div>
                <div style={{fontFamily:"'DM Mono',monospace",fontSize:'11px',color:textMuted,width:'60px',textAlign:'right'}}>{stock} {item.Unidad||'u'}</div>
              </div>
            );
          })}
        </div>
      )}
      <div style={{display:'grid',gridTemplateColumns:'1.5fr 1fr',gap:'16px'}}>
        <div>
          <TableHeader title="💰 Ventas recientes"><Btn variant="green" size="sm">⬇ Exportar</Btn></TableHeader>
          <DataTable
            columns={[
              {key:'cliente',label:'Cliente',accent:true,first:true},
              {key:'producto',label:'Producto'},
              {key:'pais',label:'País',mono:true},
              {key:'monto',label:'Monto',mono:true},
              {key:'estado',label:'Estado',render:v=><Badge status={v}>{v}</Badge>},
            ]}
            rows={ventasRecientes}
          />
        </div>
        <div style={{display:'flex',flexDirection:'column',gap:'14px'}}>
          <div style={{background:bg,border:`1px solid ${border}`,borderRadius:'12px',overflow:'hidden',boxShadow:'0 1px 4px rgba(167,0,29,.06)'}}>
            <TableHeader title="⚠️ Alertas"/>
            {facturasVencidas.slice(0,3).map((f,i)=>(
              <div key={i} style={{display:'flex',gap:'10px',padding:'10px 16px',borderTop:i>0?`1px solid ${border}`:'none',alignItems:'flex-start'}}>
                <span style={{fontSize:'14px',flexShrink:0}}>🔴</span>
                <div>
