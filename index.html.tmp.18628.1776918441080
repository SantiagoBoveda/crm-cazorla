                  <div style={{fontSize:'11px',color:textMuted,marginTop:'2px'}}>{f.FechaVencimiento||''}</div>
                </div>
              </div>
            ))}
            {facturasVencidas.length===0&&<div style={{padding:'12px 16px',fontSize:'12px',color:textMuted}}>Sin alertas activas ✓</div>}
          </div>
        </div>
      </div>
    </div>
  );
}

