/* ── Google Sheets config ── */
const SHEET_ID = '1AA7ca_EQeScaix02urKOS4xiOlRGAiisfbwABeaF0Kw';
const SCOPES   = 'https://www.googleapis.com/auth/spreadsheets';
const LS_CLIENT_ID = 'crm_client_id';

/* ── Helpers: lectura ── */
function sheetRowsToObjects(values) {
  if (!values || values.length < 2) return [];
  const headers = values[0];
  return values.slice(1)
    .filter(row => row.some(c => c !== ''))
    .map(row => {
      const o = {};
      headers.forEach((h, i) => { o[h] = row[i] || ''; });
      return o;
    });
}

async function fetchSheet(sheetName, token) {
  const url = `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${encodeURIComponent(sheetName)}!A:Z`;
  const r = await fetch(url, { headers: { Authorization: 'Bearer ' + token } });
  if (!r.ok) return [];
  const d = await r.json();
  return sheetRowsToObjects(d.values);
}

/* ── Helpers: escritura ── */
function genId() {
  return 'id_' + Date.now() + '_' + Math.random().toString(36).substr(2, 5);
}

async function rewriteSheet(sheetName, rows, token) {
  if (!rows.length) return;
  const headers = Object.keys(rows[0]);
  const values  = [headers, ...rows.map(r => headers.map(h => r[h] ?? ''))];
  // 1. limpiar
  await fetch(
    `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${encodeURIComponent(sheetName)}!A:Z:clear`,
    { method: 'POST', headers: { Authorization: 'Bearer ' + token } }
  );
  // 2. reescribir
  await fetch(
    `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${encodeURIComponent(sheetName)}!A1?valueInputOption=USER_ENTERED`,
    {
      method: 'PUT',
      headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' },
      body: JSON.stringify({ values }),
    }
  );
}

async function appendToSheet(sheetName, row, token) {
  const headers = Object.keys(row);
  const values  = [headers.map(h => row[h] ?? '')];
  await fetch(
    `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${encodeURIComponent(sheetName)}!A:Z:append?valueInputOption=USER_ENTERED`,
    {
      method: 'POST',
      headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' },
      body: JSON.stringify({ values }),
    }
  );
}

/* ── AuthOverlay ── */
function AuthOverlay({ onToken }) {
  const [clientId, setClientId] = useState(() => localStorage.getItem(LS_CLIENT_ID) || '');
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');

  const handleAuth = () => {
    const id = clientId.trim();
    if (!id.includes('.apps.googleusercontent.com')) {
      setError('Ingresá un Client ID válido (termina en .apps.googleusercontent.com)');
      return;
    }
    setError('');
    setLoading(true);
    localStorage.setItem(LS_CLIENT_ID, id);
    const client = google.accounts.oauth2.initTokenClient({
      client_id: id,
      scope: SCOPES,
      callback: (resp) => {
        setLoading(false);
        if (resp.error) { setError('Error: ' + resp.error); return; }
        onToken(resp.access_token);
      },
    });
    client.requestAccessToken();
  };

  return (
    <div style={{position:'fixed',inset:0,background:'rgba(15,16,8,.85)',display:'flex',alignItems:'center',justifyContent:'center',zIndex:9999}}>
      <div style={{background:'var(--surface,#fff)',border:'1px solid var(--border,#dad0be)',borderRadius:'16px',padding:'36px 32px',width:'100%',maxWidth:'420px',boxShadow:'0 8px 32px rgba(0,0,0,.18)'}}>
        <div style={{fontSize:'22px',fontWeight:800,color:'var(--accent,#a7001d)',marginBottom:'4px'}}>Aceitunas Cazorla</div>
        <div style={{fontSize:'13px',color:'var(--text2,#5c4e3a)',marginBottom:'24px'}}>Conectá tu Google para cargar los datos en tiempo real desde Sheets.</div>
        <label style={{fontSize:'11px',fontWeight:600,color:'var(--text2,#5c4e3a)',textTransform:'uppercase',letterSpacing:'.5px',display:'block',marginBottom:'6px'}}>Google OAuth Client ID</label>
        <input
          value={clientId}
          onChange={e => setClientId(e.target.value)}
          placeholder="xxxx.apps.googleusercontent.com"
          style={{width:'100%',padding:'10px 12px',border:'1px solid var(--border,#dad0be)',borderRadius:'8px',fontSize:'12px',fontFamily:"'DM Mono',monospace",outline:'none',marginBottom:'12px',background:'var(--surface2,#f0ebe0)',color:'var(--text,#1a0f09)'}}
        />
        {error && <div style={{fontSize:'12px',color:'#db473c',marginBottom:'12px'}}>{error}</div>}
        <button
          onClick={handleAuth}
          disabled={loading}
          style={{width:'100%',padding:'12px',background:'#a7001d',color:'#fff',border:'none',borderRadius:'10px',fontSize:'14px',fontWeight:700,cursor:loading?'not-allowed':'pointer',opacity:loading?.7:1}}
        >
          {loading ? 'Conectando…' : '🔐 Iniciar sesión con Google'}
        </button>
        <div style={{fontSize:'11px',color:'var(--text3,#9e8e78)',marginTop:'14px',textAlign:'center'}}>
          Creá el Client ID en <strong>console.cloud.google.com</strong> → APIs → Credenciales → OAuth 2.0
        </div>
      </div>
    </div>
  );
}

