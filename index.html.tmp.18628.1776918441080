          {key:'num',label:'Nº Cotiz.',mono:true,accent:true},
          {key:'fecha',label:'Fecha',mono:true},
          {key:'cliente',label:'Cliente'},
          {key:'pais',label:'País',mono:true},
          {key:'incoterm',label:'Incoterm',mono:true},
          {key:'moneda',label:'Moneda',mono:true},
          {key:'estado',label:'Estado',render:v=><Badge status={v}>{v}</Badge>},
        ]}
        rows={filtered}
        onEdit={()=>{}} onDelete={()=>{}}
      />
    </div>
  );
}

/* ── Pipeline ── */
function PipelineScreen({theme, data}) {
  const border=theme==='dark'?'#2e3018':'#dad0be';
  const bg=theme==='dark'?'#191b0d':'#fff';
  const ventas = data.ventas;

  const STAGE_CONFIG=[
    {id:'cotización',label:'Cotización',color:'#94a3b8'},
    {id:'confirmada',label:'Confirmada',color:'#a7001d'},
    {id:'despachada',label:'Despachada',color:'#b45309'},
    {id:'cobrada',label:'Cobrada',color:'#6b7215'},
    {id:'cancelada',label:'Cancelada',color:'#db473c'},
  ];

  const stages = STAGE_CONFIG.map(s=>{
    const items = ventas.filter(v=>(v.Etapa||v.Estado||'').toLowerCase()===s.id);
    const total = items.reduce((sum,v)=>sum+(parseFloat(v.ValorUSD)||0),0);
    return {...s, count:items.length, usd: total?`$${total.toLocaleString('es-AR')}`:'$0'};
  });

  const dealsActivos = ventas.slice(-6).reverse().map(v=>({
    num: v.NumOrden||v.NroOrden||v.ID||'',
    fecha: v.Fecha||v.FechaCarga||'',
    cliente: v.Cliente||'',
    pais: v.Pais||'',
    monto: v.ValorUSD?`$${Number(v.ValorUSD).toLocaleString('es-AR')}`:'—',
    estado: (v.Etapa||v.Estado||'').toLowerCase(),
    _overdue: (v.Etapa||v.Estado||'').toLowerCase()==='vencida',
  }));

  return (
    <div>
      <PageHeader title="🔀 Pipeline de Ventas" subtitle="Embudo comercial · estado actual"/>
      <div style={{display:'grid',gridTemplateColumns:'repeat(5,1fr)',gap:'12px',marginBottom:'20px'}}>
        {stages.map(s=>(
          <div key={s.id} style={{background:bg,border:`1px solid ${border}`,borderRadius:'12px',padding:'16px',textAlign:'center',position:'relative',overflow:'hidden',boxShadow:'0 1px 4px rgba(167,0,29,.06)'}}>
            <div style={{position:'absolute',top:0,left:0,right:0,height:'3px',background:s.color}}></div>
            <div style={{fontSize:'10px',textTransform:'uppercase',letterSpacing:'.6px',color:'#9e8e78',marginBottom:'8px',fontFamily:"'DM Mono',monospace"}}>{s.label}</div>
            <div style={{fontSize:'30px',fontWeight:800,color:s.color,lineHeight:1,marginBottom:'4px'}}>{s.count}</div>
            <div style={{fontSize:'12px',fontFamily:"'DM Mono',monospace",color:'#6e5f4e'}}>{s.usd}</div>
          </div>
        ))}
      </div>
      <TableHeader title="Ventas recientes"/>
      <DataTable
        columns={[
          {key:'num',label:'ID',mono:true,accent:true},
          {key:'fecha',label:'Fecha',mono:true},
          {key:'cliente',label:'Cliente'},
          {key:'pais',label:'País',mono:true},
          {key:'monto',label:'Monto',mono:true},
          {key:'estado',label:'Etapa',render:v=><Badge status={v}>{v}</Badge>},
        ]}
        rows={dealsActivos}
      />
    </div>
  );
}

/* ── Facturación ── */
function FacturacionScreen({theme, data}) {
  const [filter,setFilter]=useState('todos');
  const FILTERS=['todos','emitida','enviada','cobrada','vencida'];
  const facturas = data.facturas;

  const rows = facturas.map(f=>({
    num: f.NumFactura||f.ID||'',
    fecha: f.FechaEmision||'',
    vence: f.FechaVencimiento||'',
    cliente: f.Cliente||'',
    monto: f.Monto?`$${Number(f.Monto).toLocaleString('es-AR')}`:'—',
    estado: (f.Estado||f.EstadoFactura||'').toLowerCase(),
    _overdue: (f.Estado||f.EstadoFactura||'').toLowerCase()==='vencida',
  }));
  const filtered = filter==='todos' ? rows : rows.filter(f=>f.estado===filter);

  const totalEmitido = facturas.reduce((s,f)=>s+(parseFloat(f.Monto)||0),0);
  const cobrado = facturas.filter(f=>(f.Estado||f.EstadoFactura||'').toLowerCase()==='cobrada').reduce((s,f)=>s+(parseFloat(f.Monto)||0),0);
  const vencidas = facturas.filter(f=>(f.Estado||f.EstadoFactura||'').toLowerCase()==='vencida').reduce((s,f)=>s+(parseFloat(f.Monto)||0),0);

  return (
    <div>
      <PageHeader title="🧾 Facturación" subtitle="Gestión de facturas emitidas"
        actions={<Btn>+ Nueva factura</Btn>}
      />
      <div style={{display:'grid',gridTemplateColumns:'repeat(4,1fr)',gap:'12px',marginBottom:'20px'}}>
        <StatCard label="Total emitido" value={`$${totalEmitido.toLocaleString('es-AR')}`} barColor="#a7001d"/>
        <StatCard label="Cobrado" value={`$${cobrado.toLocaleString('es-AR')}`} barColor="#6b7215"/>
        <StatCard label="Pendiente" value={`$${(totalEmitido-cobrado).toLocaleString('es-AR')}`} barColor="#b45309" subColor="#9e8e78"/>
        <StatCard label="Vencidas" value={`$${vencidas.toLocaleString('es-AR')}`} barColor="#db473c" subColor="#db473c"/>
      </div>
      <div style={{display:'flex',gap:'8px',marginBottom:'14px',flexWrap:'wrap'}}>
        {FILTERS.map(f=><FilterPill key={f} label={f.charAt(0).toUpperCase()+f.slice(1)} active={filter===f} onClick={()=>setFilter(f)}/>)}
      </div>
      <DataTable
        columns={[
          {key:'num',label:'Nº Factura',mono:true,accent:true,first:true},
          {key:'fecha',label:'Emisión',mono:true},
          {key:'vence',label:'Vence',mono:true},
          {key:'cliente',label:'Cliente'},
          {key:'monto',label:'Monto',mono:true},
          {key:'estado',label:'Estado',render:v=><Badge status={v}>{v}</Badge>},
        ]}
        rows={filtered}
        onEdit={()=>{}} onDelete={()=>{}}
      />
    </div>
  );
}

