/* ── App ── */
function App() {
  const [section,setSection]=useState(()=>localStorage.getItem('crm_section2')||'dashboard');
  const [theme,setTheme]=useState(()=>localStorage.getItem('crm_theme')||'light');
  const [token,setToken]=useState(null);
  const [loading,setLoading]=useState(false);
  const [saving,setSaving]=useState(false);
  const [data,setData]=useState(SAMPLE);
  const [syncTime,setSyncTime]=useState(null);

  useEffect(()=>{
    document.body.className=theme==='dark'?'warm':'';
    localStorage.setItem('crm_theme',theme);
  },[theme]);

  const loadFromSheets = useCallback(async (tok) => {
    setLoading(true);
    try {
      const [ventas,clientes,cotizaciones,facturas,inventario,proyectos,reclamos,prevision] = await Promise.all([
        fetchSheet('Ventas',tok), fetchSheet('Clientes',tok), fetchSheet('Cotizaciones',tok),
        fetchSheet('Facturas',tok), fetchSheet('Inventario',tok), fetchSheet('Proyectos',tok),
        fetchSheet('Reclamos',tok), fetchSheet('Prevision',tok),
      ]);
      setData({ventas,clientes,cotizaciones,facturas,inventario,proyectos,reclamos,prevision});
      setSyncTime(new Date().toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'}));
    } catch(e){ console.error('Error cargando Sheets:',e); }
    setLoading(false);
  },[]);

  const handleToken = useCallback((tok)=>{ setToken(tok); loadFromSheets(tok); },[loadFromSheets]);
  const navigate=(id)=>{setSection(id);localStorage.setItem('crm_section2',id);};
  const toggleTheme=()=>setTheme(t=>t==='dark'?'light':'dark');

  /* ── Mutaciones ── */
  const addRecord = useCallback(async (sheetName, dbKey, record) => {
    const newRecord = { ID: genId(), ...record };
    setSaving(true);
    try {
      const newRows = [...(data[dbKey]||[]), newRecord];
      setData(prev=>({...prev,[dbKey]:newRows}));
      await appendToSheet(sheetName, newRecord, token);
      setSyncTime(new Date().toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'}));
    } catch(e){ console.error('Error guardando:',e); }
    setSaving(false);
    return newRecord;
  },[data,token]);

  const updateRecord = useCallback(async (sheetName, dbKey, id, record) => {
    setSaving(true);
    try {
      const newRows = (data[dbKey]||[]).map(r=>(r.ID===id?{...r,...record}:r));
      setData(prev=>({...prev,[dbKey]:newRows}));
      await rewriteSheet(sheetName, newRows, token);
      setSyncTime(new Date().toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'}));
    } catch(e){ console.error('Error actualizando:',e); }
    setSaving(false);
  },[data,token]);

  const deleteRecord = useCallback(async (sheetName, dbKey, id) => {
    if(!confirm('¿Eliminar este registro?')) return;
    setSaving(true);
    try {
      const newRows = (data[dbKey]||[]).filter(r=>r.ID!==id);
      setData(prev=>({...prev,[dbKey]:newRows}));
      await rewriteSheet(sheetName, newRows, token);
      setSyncTime(new Date().toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'}));
    } catch(e){ console.error('Error eliminando:',e); }
    setSaving(false);
  },[data,token]);

  const mutations = { addRecord, updateRecord, deleteRecord };

  const screens={
    dashboard:    <DashboardScreen theme={theme} data={data}/>,
    clientes:     <ClientesScreen theme={theme} data={data} mutations={mutations} token={token}/>,
    contactos:    <ContactosScreen theme={theme}/>,
    cotizaciones: <CotizacionesScreen theme={theme} data={data} mutations={mutations} token={token}/>,
    pipeline:     <PipelineScreen theme={theme} data={data}/>,
    inventario:   <InventarioScreen theme={theme}/>,
    ventas:       <VentasScreen theme={theme} data={data} mutations={mutations} token={token}/>,
    prevision:    <PrevisionScreen theme={theme}/>,
    proveedores:  <ProveedoresScreen theme={theme}/>,
    reclamos:     <ReclamosScreen theme={theme}/>,
    facturacion:  <FacturacionScreen theme={theme} data={data} mutations={mutations} token={token}/>,
    cargas:       <CargasScreen theme={theme}/>,
    proyectos:    <ProyectosScreen theme={theme}/>,
    calendario:   <CalendarioScreen theme={theme}/>,
  };

  return (
    <div>
      {!token && <AuthOverlay onToken={handleToken}/>}
      <Sidebar active={section} onNav={navigate} theme={theme} onToggleTheme={toggleTheme}/>
      <div className="main-content">
        {loading
          ? <div style={{display:'flex',alignItems:'center',justifyContent:'center',height:'60vh',flexDirection:'column',gap:'16px'}}>
              <div style={{width:'36px',height:'36px',border:'3px solid #dad0be',borderTopColor:'#a7001d',borderRadius:'50%',animation:'spin .8s linear infinite'}}/>
              <div style={{fontSize:'13px',color:'#9e8e78'}}>Cargando datos desde Google Sheets…</div>
            </div>
          : screens[section]||screens.dashboard
        }
        {token && syncTime && !loading && (
          <div style={{position:'fixed',bottom:'16px',right:'20px',fontSize:'11px',color:'#9e8e78',background:'var(--surface,#fff)',border:'1px solid var(--border,#dad0be)',borderRadius:'8px',padding:'6px 12px',display:'flex',alignItems:'center',gap:'8px'}}>
            <span style={{width:'7px',height:'7px',borderRadius:'50%',background:'#6b7215',display:'inline-block'}}/>
            Sheets · actualizado {syncTime}
            <button onClick={()=>loadFromSheets(token)} style={{background:'none',border:'none',color:'#a7001d',cursor:'pointer',fontWeight:700,fontSize:'11px',padding:'0 0 0 4px'}}>↻</button>
          </div>
        )}
      </div>
      <style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>

<div id="root"></div>
</body>
</html>
